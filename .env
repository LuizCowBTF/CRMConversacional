# ============================================================================
# CRM CONVERSACIONAL - VARIÁVEIS DE AMBIENTE
# ============================================================================
# ATENÇÃO: Este arquivo NÃO deve ser commitado no GitHub!
# Copie para .env e preencha com seus valores reais
# ============================================================================

# -------------------- FLASK --------------------
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=seu-segredo-aqui-muito-forte-com-32-caracteres-minimo
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# -------------------- BANCO DE DADOS --------------------
# Para desenvolvimento: SQLite
DATABASE_URL=sqlite:///instance/crm.db

# Para produção (recomendado PostgreSQL):
# DATABASE_URL=postgresql://usuario:senha@postgres:5432/crm_db

# -------------------- WHATSAPP CLOUD API (META) --------------------
WHATSAPP_ACCESS_TOKEN=EAAM___________________________________________
WHATSAPP_PHONE_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=seu_token_verificacao_unico
WHATSAPP_API_VERSION=v18.0

# -------------------- OPENAI (IA para decisões) --------------------
OPENAI_API_KEY=sk-proj-________________________________________________
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# -------------------- REDIS (Cache e Rate Limiting) --------------------
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_SSL=False

# -------------------- SEGURANÇA E RATE LIMITING --------------------
RATELIMIT_DEFAULT=200 per day, 50 per hour
RATELIMIT_STORAGE_URL=redis://redis:6379/0
RATELIMIT_STRATEGY=fixed-window

# -------------------- ADMIN PADRÃO (primeiro acesso) --------------------
ADMIN_EMAIL=admin@crm.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# -------------------- MULTI-TENANT (SaaS) --------------------
DEFAULT_SUBDOMAIN=app
TENANT_MODE=True

# -------------------- UPLOAD DE ARQUIVOS --------------------
MAX_CONTENT_LENGTH=26214400  # 25MB em bytes
UPLOAD_FOLDER=static/uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,pdf,doc,docx,xls,xlsx,mp3,mp4

# -------------------- EMAIL (para recuperação de senha) --------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app
MAIL_DEFAULT_SENDER=CRM Conversacional <noreply@crm.com>

# -------------------- LOGGING --------------------
LOG_LEVEL=INFO
LOG_FILE=logs/crm.log

# -------------------- NOTIFICAÇÕES --------------------
POLLING_INTERVAL=15000  # milissegundos (15 segundos)
SOUND_NOTIFICATION=True

# -------------------- FEATURE FLAGS --------------------
ENABLE_WHATSAPP=True
ENABLE_AI=True
ENABLE_MULTI_TENANT=False
ENABLE_DARK_MODE=True