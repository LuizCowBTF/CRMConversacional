# ============================================================================
# CRM CONVERSACIONAL - EXEMPLO DE VARIÁVEIS DE AMBIENTE
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores
# ============================================================================

# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=mude-para-uma-chave-segura
SESSION_COOKIE_SECURE=False

# Banco de Dados (SQLite para dev)
DATABASE_URL=sqlite:///instance/crm.db

# WhatsApp (opcional - deixe vazio se não usar)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# OpenAI (opcional - deixe vazio se não usar)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Redis (opcional)
REDIS_URL=redis://localhost:6379/0

# Admin padrão
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=admin123

# Multi-tenant
TENANT_MODE=False